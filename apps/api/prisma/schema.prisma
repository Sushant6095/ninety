// Durable truth (README data-flow rule 3). Hot state lives in Redis.
generator client {
  provider = "prisma-client-js"
}

// Supabase two-URL split (ITEM 11 / SETUP-LIVE.md). The app runs through the SUPABASE POOLER (PgBouncer,
// transaction mode) so serverless/multi-process connections don't exhaust Postgres:
//   DATABASE_URL = ...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
// Migrations CANNOT run through PgBouncer (it can't hold the session-level advisory locks Prisma needs — they
// hang forever), so `prisma migrate deploy` uses the DIRECT :5432 connection:
//   DIRECT_URL   = ...db.<ref>.supabase.co:5432/postgres
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String         @id @default(uuid())
  handle       String         @unique
  walletPubkey String         @unique
  authKind     String // embedded | external  (ADR-006)
  createdAt    DateTime       @default(now())
  positions    Position[]
  orders       Order[]
  credits      CreditLedger[]
}

model Match {
  id        String   @id // txline match id
  stage     String
  kickoffAt DateTime
  status    String
  minute    Int? // live clock minute from TxLINE; null pre-match/settled. The live read path's source (was absent — audit gap).
  score     String? // live score "home-away", e.g. "0-1", from TxLINE; null pre-match. Feeds the SSOT score read path.
  home      String
  away      String
  markets   Market[]
}

model Market {
  id             String     @id
  matchId        String
  kind           String     @default("1X2") // ADR-001
  status         String     @default("SCHEDULED")
  bParam         Float      @default(300)
  settledOutcome String?
  settleSig      String?
  match          Match      @relation(fields: [matchId], references: [id])
  orders         Order[]
  positions      Position[]
}

model Order {
  id       String   @id @default(uuid())
  userId   String
  marketId String
  outcome  String // H | D | A
  side     String // buy | sell
  size     Int
  status   String
  ts       DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])
  market   Market   @relation(fields: [marketId], references: [id])
  fills    Fill[]
}

model Fill {
  id      String   @id @default(uuid())
  orderId String
  price   Float
  size    Int
  fee     Float
  ts      DateTime @default(now())
  order   Order    @relation(fields: [orderId], references: [id])
}

model Position {
  userId      String
  marketId    String
  outcome     String
  qty         Int
  avgPrice    Float
  realizedPnl Float  @default(0)
  user        User   @relation(fields: [userId], references: [id])
  market      Market @relation(fields: [marketId], references: [id])

  @@id([userId, marketId, outcome])
}

model CreditLedger {
  id      String   @id @default(uuid())
  userId  String
  matchId String
  delta   Float // credits are fractional play-money (LMSR cost is a float); Σ(delta) per user == balance (ADR-003)
  reason  String
  ts      DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id])
}

model SettlementSaga {
  marketId  String   @id
  step      String
  state     String
  updatedAt DateTime @updatedAt
}

model Settlement {
  marketId  String @id
  result    String
  proofHash String
  solanaSig String
  lbRoot    String
}

model Moment {
  id       String  @id @default(uuid())
  marketId String
  imageUri String
  mintSig  String?
}

model ChainEvent {
  sig     String @id
  program String
  kind    String
  payload Json
  slot    BigInt
}

// Idempotency inbox for the bus→DB projection (ADR-027). One row per consumed event_id, inserted in the SAME
// transaction as the projected rows — re-consuming an event hits the PK and the whole apply is skipped, so the
// projection is exactly-once ("zero duplicate rows on re-consume"). Redis hot state derives from these writes.
model ProcessedEvent {
  eventId String   @id
  topic   String
  ts      DateTime @default(now())
}
