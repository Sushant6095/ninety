# GitHub Linguist language stats
# design/ holds reference material — exported "lock-kit" HTML mockups, screenshots, and
# token references — not application source. Exclude it so the language breakdown reflects
# the actual TypeScript (apps/, packages/) + Rust (programs/) codebase, not 3.7 MB of design HTML.
design/** linguist-vendored

# Belt and braces: any standalone HTML export is a design/doc artifact, never app source
# (the app is Next.js/TSX — it ships no hand-written .html).
*.html linguist-vendored

# Tooling, not shipped product: live TxLINE probes, deploy/replay/screenshot scripts, and
# build configs. Excluding them lets the language bar reflect the app + on-chain program,
# not dev ergonomics. (We do NOT vendor real source under apps/ or packages/.)
scripts/** linguist-vendored
*.config.js linguist-vendored
*.config.mjs linguist-vendored
