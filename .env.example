# --- TxLINE (L1) --- optional: the mock + replay run without a token
TXLINE_TOKEN=
TXLINE_BASE_URL=https://txline-dev.txodds.com

# --- Data platform (L2) --- docker-compose maps Postgres to HOST PORT 5433 (5432 left free on purpose)
DATABASE_URL=postgresql://omnipitch:omnipitch@localhost:5433/omnipitch
DIRECT_URL=postgresql://omnipitch:omnipitch@localhost:5433/omnipitch   # direct (non-pooled) for prisma migrate
REDIS_URL=redis://localhost:6379
BUS_DRIVER=redis            # redis | kafka  (ADR-007; kafka driver is a stub today)

# --- API secrets --- dev falls back to insecure defaults; PRODUCTION BOOT THROWS if unset
JWT_SECRET=
EMBEDDED_WALLET_SECRET=
ADMIN_TOKEN=                # unset = every /admin/* call rejected (secure default)
HELIUS_WEBHOOK_SECRET=      # fail-closed verify on POST /webhooks/helius

# --- Solana (L0) ---
SOLANA_CLUSTER=devnet
HELIUS_API_KEY=
OMNIPITCH_PROGRAM_ID=6ps8ao7CVhacnRajvFXWTmkknsRnHfEbWmtQ3nDCdBkj   # devnet default; webhook program filter
SETTLEMENT_KEYPAIR_PATH=./.keys/settlement.json

# --- AI booth (worker-jobs) --- optional: deterministic template narrator without a key
ANTHROPIC_API_KEY=
TTS_API_KEY=

# --- EarlyWhistle Telegram cards (worker-jobs) --- optional: skipped when unset
TELEGRAM_BOT_TOKEN=
EARLYWHISTLE_CHANNEL=
APP_URL=

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4001   # uWS gateway (WS_PORT, default 4001; Fly exposes it as TLS :8443)
