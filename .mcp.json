{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://omnipitch:omnipitch@localhost:5432/omnipitch"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    },
    "css-studio": {
      "command": "npx",
      "args": [
        "-y",
        "cssstudio"
      ]
    },
    "magicui": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ],
      "env": {}
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=atpctubvfyknizwqbtyl"
    },
    "fly": {
      "command": "fly",
      "args": ["mcp", "server"]
    }
  }
}